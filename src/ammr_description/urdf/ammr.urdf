<?xml version="1.0"?>
<!--
  Stallentis AMMR (autonomous mobile manipulator robot) - digital-twin model.

  Source of truth: 2. Stallentis AMMR_Layout 2D Drawing_260106.pdf + "ammr기구학":
    body 1244 x 794 x 720 mm, ground clearance 28 mm, LiDAR scan height 99.5 mm
    SWERVE drive, 2 diagonal modules: right_front [0.364, -0.137],
    left_rear [-0.364, 0.137]; wheel r 75 mm, width 50 mm
    wheel_base 728 mm, wheel_track 274 mm; max drive 1.12 m/s, steer 1.24 rad/s
    Nav2 footprint 1.25 x 0.8 m; turning circle from drawing: dia 1460 mm

  Each swerve module = steering joint (z, continuous) + wheel joint (y, continuous).
  Four corner casters are modelled as low-friction spheres (the real robot's
  passive rollers); they carry the body while the two modules drive/steer.
  The manipulator is a fixed visual mock (teleop/driving twin only).
-->
<robot name="ammr">

  <material name="body_grey"><color rgba="0.55 0.57 0.60 1.0"/></material>
  <material name="deck_orange"><color rgba="0.90 0.45 0.10 1.0"/></material>
  <material name="wheel_black"><color rgba="0.12 0.12 0.12 1.0"/></material>
  <material name="arm_white"><color rgba="0.85 0.85 0.88 1.0"/></material>

  <!-- ================= base ================= -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- chassis box spans z 0.028..0.640 (deck below the 0.72 top plate) -->
    <origin xyz="0 0 0.334" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="1.244 0.794 0.612"/></geometry>
      <material name="body_grey"/>
    </visual>
    <visual>
      <!-- top plate (deck) -->
      <origin xyz="0 0 0.346" rpy="0 0 0"/>
      <geometry><box size="1.244 0.794 0.080"/></geometry>
      <material name="deck_orange"/>
    </visual>
    <collision>
      <geometry><box size="1.244 0.794 0.612"/></geometry>
    </collision>
    <inertial>
      <mass value="120.0"/>
      <!-- solid box approx: 1/12 m (b^2+c^2) -->
      <inertia ixx="10.05" iyy="19.22" izz="21.78" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ================= LiDAR (scan plane 99.5 mm) ================= -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_scan"/>
    <origin xyz="0.58 0 0.0995" rpy="0 0 0"/>
  </joint>
  <link name="base_scan">
    <visual>
      <geometry><cylinder radius="0.035" length="0.04"/></geometry>
      <material name="wheel_black"/>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ================= swerve module macro (expanded) =================
       module frame at wheel-axle height z = 0.075 (wheel r 0.075) -->

  <!-- right_front module @ [0.364, -0.137] -->
  <joint name="right_front_steer_joint" type="continuous">
    <parent link="base_footprint"/>
    <child link="right_front_steer_link"/>
    <origin xyz="0.364 -0.137 0.075" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="80.0" velocity="1.24"/>
  </joint>
  <link name="right_front_steer_link">
    <visual>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="0.10"/></geometry>
      <material name="body_grey"/>
    </visual>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="right_front_wheel_joint" type="continuous">
    <parent link="right_front_steer_link"/>
    <child link="right_front_wheel_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="60.0" velocity="15.0"/>
  </joint>
  <link name="right_front_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="0.075" length="0.050"/></geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="0.075" length="0.050"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.0032" iyy="0.0056" izz="0.0032" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- left_rear module @ [-0.364, 0.137] -->
  <joint name="left_rear_steer_joint" type="continuous">
    <parent link="base_footprint"/>
    <child link="left_rear_steer_link"/>
    <origin xyz="-0.364 0.137 0.075" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="80.0" velocity="1.24"/>
  </joint>
  <link name="left_rear_steer_link">
    <visual>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="0.10"/></geometry>
      <material name="body_grey"/>
    </visual>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="left_rear_wheel_joint" type="continuous">
    <parent link="left_rear_steer_link"/>
    <child link="left_rear_wheel_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="60.0" velocity="15.0"/>
  </joint>
  <link name="left_rear_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="0.075" length="0.050"/></geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="0.075" length="0.050"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.0032" iyy="0.0056" izz="0.0032" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ================= corner casters (passive rollers) =================
       modelled as spheres; friction is zeroed on the Isaac side -->
  <joint name="caster_fl_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="caster_fl_link"/>
    <origin xyz="0.55 0.33 0.05" rpy="0 0 0"/>
  </joint>
  <link name="caster_fl_link">
    <visual><geometry><sphere radius="0.05"/></geometry><material name="wheel_black"/></visual>
    <collision><geometry><sphere radius="0.05"/></geometry></collision>
    <inertial><mass value="0.5"/><inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="caster_fr_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="caster_fr_link"/>
    <origin xyz="0.55 -0.33 0.05" rpy="0 0 0"/>
  </joint>
  <link name="caster_fr_link">
    <visual><geometry><sphere radius="0.05"/></geometry><material name="wheel_black"/></visual>
    <collision><geometry><sphere radius="0.05"/></geometry></collision>
    <inertial><mass value="0.5"/><inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="caster_rl_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="caster_rl_link"/>
    <origin xyz="-0.55 0.33 0.05" rpy="0 0 0"/>
  </joint>
  <link name="caster_rl_link">
    <visual><geometry><sphere radius="0.05"/></geometry><material name="wheel_black"/></visual>
    <collision><geometry><sphere radius="0.05"/></geometry></collision>
    <inertial><mass value="0.5"/><inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="caster_rr_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="caster_rr_link"/>
    <origin xyz="-0.55 -0.33 0.05" rpy="0 0 0"/>
  </joint>
  <link name="caster_rr_link">
    <visual><geometry><sphere radius="0.05"/></geometry><material name="wheel_black"/></visual>
    <collision><geometry><sphere radius="0.05"/></geometry></collision>
    <inertial><mass value="0.5"/><inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>

  <!-- ================= manipulator mock (visual only) ================= -->
  <joint name="arm_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_link"/>
    <!-- rear-right of the deck per the drawing iso view -->
    <origin xyz="0.35 -0.15 0.386" rpy="0 0 0"/>
  </joint>
  <link name="arm_link">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry><cylinder radius="0.075" length="0.20"/></geometry>
      <material name="arm_white"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.42" rpy="0 0 0"/>
      <geometry><cylinder radius="0.055" length="0.45"/></geometry>
      <material name="arm_white"/>
    </visual>
    <visual>
      <origin xyz="0.12 0 0.66" rpy="0 1.2 0"/>
      <geometry><cylinder radius="0.045" length="0.40"/></geometry>
      <material name="arm_white"/>
    </visual>
    <inertial>
      <mass value="18.0"/>
      <inertia ixx="0.5" iyy="0.5" izz="0.2" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

</robot>
