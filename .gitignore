# colcon build artifacts (machine-specific, must be rebuilt per machine)
build/
install/
log/

# Scan outputs (large, regenerated on every scan)
*.csv

# Editor / OS cruft
.vscode/
.idea/
*.swp
*~
.DS_Store

# Sim test logs (regenerated)
scripts/last_test/

# Python cache
__pycache__/
*.pyc

# e57 processing venv
.e57venv/

# Proprietary Leica BLK360 runtime library — NOT redistributable.
# Supply it locally to build blk360_scanner (see third_party/lib/README.md).
src/blk360_scanner/third_party/lib/*.so
